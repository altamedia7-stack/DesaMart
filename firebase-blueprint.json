{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the marketplace (buyer, seller, or admin)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "seller", "buyer"] },
        "whatsapp": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A product listed by a seller",
      "type": "object",
      "properties": {
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerWhatsapp": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "discountPercentage": { "type": "number" },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "stock": { "type": "number" },
              "discountPercentage": { "type": "number" }
            },
            "required": ["id", "name", "price", "stock"]
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sellerId", "sellerName", "sellerWhatsapp", "name", "description", "price", "category", "imageUrl", "createdAt"]
    },
    "Courier": {
      "title": "Courier",
      "description": "A courier service for delivery",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "baseRate": { "type": "number" },
        "perKmRate": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "baseRate", "perKmRate", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "message", "isRead", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a buyer to a seller",
      "type": "object",
      "properties": {
        "buyerId": { "type": "string" },
        "buyerName": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "items": { "type": "array" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "shipped", "in_transit", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerId", "buyerName", "sellerId", "sellerName", "items", "totalPrice", "status", "createdAt", "updatedAt"]
    },
    "TravelListing": {
      "title": "TravelListing",
      "description": "A travel route and schedule listed by a seller",
      "type": "object",
      "properties": {
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerWhatsapp": { "type": "string" },
        "operatorName": { "type": "string" },
        "origin": { "type": "string" },
        "destination": { "type": "string" },
        "departureTime": { "type": "string" },
        "price": { "type": "number" },
        "totalSeats": { "type": "number" },
        "availableSeats": { "type": "number" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sellerId", "sellerName", "sellerWhatsapp", "operatorName", "origin", "destination", "departureTime", "price", "totalSeats", "availableSeats", "createdAt"]
    },
    "TravelBooking": {
      "title": "TravelBooking",
      "description": "A travel booking made by a buyer",
      "type": "object",
      "properties": {
        "buyerId": { "type": "string" },
        "buyerName": { "type": "string" },
        "sellerId": { "type": "string" },
        "listingId": { "type": "string" },
        "operatorName": { "type": "string" },
        "origin": { "type": "string" },
        "destination": { "type": "string" },
        "departureDate": { "type": "string" },
        "departureTime": { "type": "string" },
        "passengers": { "type": "array" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerId", "buyerName", "sellerId", "listingId", "operatorName", "origin", "destination", "departureDate", "departureTime", "passengers", "totalPrice", "status", "paymentMethod", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Stores product listings"
    },
    "/couriers/{courierId}": {
      "schema": { "$ref": "#/entities/Courier" },
      "description": "Stores courier services and rates"
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Stores user notifications"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Stores orders placed by buyers"
    },
    "/travel_listings/{listingId}": {
      "schema": { "$ref": "#/entities/TravelListing" },
      "description": "Stores travel route listings"
    },
    "/travel_bookings/{bookingId}": {
      "schema": { "$ref": "#/entities/TravelBooking" },
      "description": "Stores travel bookings"
    }
  }
}
